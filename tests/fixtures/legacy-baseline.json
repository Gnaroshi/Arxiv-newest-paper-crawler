{
  "baselineCommit": "f633ce2a3ad3ea9818eed10af1cb2fe09eeca8cf",
  "commands": {
    "default": "all",
    "process": ["collect", "download-all-matching-pdfs", "translate-when-client-configures", "write-papers-json"],
    "serve": ["run-flask-ui"],
    "all": ["process", "serve"]
  },
  "runtimeFiles": {
    "papers": "papers.json",
    "favorites": "favorites.json",
    "pdfDirectory": "pdfs"
  },
  "web": {
    "routes": ["/", "/all", "/favorite/<short_id>"],
    "host": "0.0.0.0",
    "port": 8080,
    "debug": true
  },
  "collection": {
    "cutoffLocalHour": 7,
    "timezoneAssumption": "Asia/Seoul via fixed UTC+09 conversion",
    "deduplication": "none",
    "sameDayBehavior": "skip when papers.json modification time is after local 07:00"
  },
  "preserve": [
    "python main.py process",
    "python main.py serve",
    "python main.py all",
    "favorites keyed by short_id",
    "Flask favorites and all-papers views",
    "English abstract when translation fails"
  ],
  "knownRisks": [
    "legacy process and all download every matching PDF",
    "legacy translation is attempted during processing",
    "papers.json is overwritten directly",
    "Flask listens on all interfaces with debug enabled"
  ]
}
