# Optional CLI-only Gemini key. The macOS app stores its key in Keychain.
GEMINI_API_KEY=

# Optional crawler overrides.
ARXIV_PAPER_CRAWLER_DAYS_TO_SEARCH=1
ARXIV_PAPER_CRAWLER_MAX_RESULTS=200
ARXIV_PAPER_CRAWLER_DOWNLOAD_PDFS=false
ARXIV_PAPER_CRAWLER_AI_CATEGORIES=cs.AI,cs.LG,cs.CV,cs.CL,cs.NE,stat.ML

# Optional runtime overrides.
ARXIV_PAPER_CRAWLER_GEMINI_MODEL=gemini-3.5-flash
ARXIV_PAPER_CRAWLER_TRANSLATION_DELAY_SECONDS=1
