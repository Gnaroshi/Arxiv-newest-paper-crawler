{
  "schemaVersion": 1,
  "id": "arxiv-crawler",
  "displayName": "Arxiv Discovery",
  "repository": "Gnaroshi/Arxiv-newest-paper-crawler",
  "version": "0.3.0",
  "platforms": ["macos", "linux"],
  "kind": "application",
  "bundleId": "",
  "dataOwner": "arxiv-crawler",
  "capabilities": [
    "discover-papers",
    "export-candidates",
    "send-to-paperflow",
    "send-to-paper-lab",
    "open-arxiv-paper",
    "launch-discovery"
  ],
  "entrypoints": {
    "app": {},
    "cli": {
      "executable": "arxiv-discovery",
      "versionSubcommand": ["version", "--json"],
      "statusSubcommand": ["status", "--json"],
      "healthSubcommand": ["doctor", "--json"],
      "recentActivitySubcommand": ["recent", "--json", "--limit", "5"]
    },
    "localHttp": {},
    "deepLinks": []
  },
  "health": { "contractVersion": 1, "timeoutMs": 3000, "freshnessSeconds": 86400 },
  "icon": { "kind": "system", "name": "scan-search" },
  "privacy": {
    "classification": "private-summary",
    "credentials": "provider-owned",
    "localPaths": "redacted"
  },
  "integration": {
    "contractVersion": 1,
    "minimumStudioVersion": "0.1.0",
    "purpose": "Discover recent papers and preview selected candidates for handoff.",
    "readOnly": true
  },
  "distribution": {
    "source": { "branch": "main", "mode": "git-fetch" },
    "release": { "provider": "github-releases", "channel": "stable", "manifestAsset": "gnaroshi.app.json" }
  }
}
